# Timezone configuration
TZ=Etc/UTC

# readsb runtime user (root recommended for USB RTL-SDR)
READSB_USER=root

# User and Group IDs (optional, used with non-root READSB_USER)
# PUID=911
# PGID=911

# File mask (default: 022, use 002 for group-writable files)
UMASK=022

# Additional readsb arguments
# Examples:
#   --net --device-type rtlsdr
#   --net --device-type rtlsdr --gain 40 (to override automatic)
#   --net --device-type rtlsdr --freq-correction 10
#   --net --lon 0 --lat 0  (network-only mode with location)
READSB_ARGS=--net --device-type rtlsdr

# Container restart policy
# Options: no, always, unless-stopped, on-failure
RESTART_POLICY=unless-stopped

# Docker Compose service name
COMPOSE_SERVICE_NAME=readsb
COMPOSE_PROJECT_NAME=readsb
