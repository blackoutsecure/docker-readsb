# macOS resource forks (created on non-HFS volumes / network shares).
._*
.AppleDouble
.LSOverride

# Python / Node tooling (defensive — added only if these stacks land).
__pycache__/
*.py[cod]
.venv/
venv/
node_modules/
npm-debug.log*

# direnv — environment loaders are per-developer.
.envrc
.direnv/

