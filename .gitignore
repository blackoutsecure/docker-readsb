# Environment and secrets
.env
.env.*
.secrets/

# Editor and IDE
.vscode/
.idea/
*.swp
.*.swp
*~
*.swo
.DS_Store
Thumbs.db

# Build artifacts
*.o
*.so
*.log
.tmp-config/
tmp/

# Runtime and local development
/local/
/.local/
.cache/
*.tmp

# Version and patch files
.version
*.orig
*.rej
*.patch

# TLS / private keys — NEVER commit.
*.pem
*.key
*.crt
*.p12
*.pfx
secrets.*

# macOS resource forks (created on non-HFS volumes / network shares).
._*
.AppleDouble
.LSOverride

# Python / Node tooling (defensive — added only if these stacks land).
__pycache__/
*.py[cod]
.venv/
venv/
node_modules/
npm-debug.log*

# direnv — environment loaders are per-developer.
.envrc
.direnv/
