#!/usr/bin/with-contenv bash

set -euo pipefail

# ── Logging ───────────────────────────────────────────────────────────────────
SVC_NAME="svc-readsb"
# shellcheck source=/usr/local/bin/log-functions.sh
. /usr/local/bin/log-functions.sh

readsb_user=${READSB_USER:-abc}
readsb_run_dir=${READSB_RUN_DIR:-/run/readsb}
tar1090_db_path=${TAR1090_DB_PATH:-/usr/local/share/tar1090/aircraft.csv.gz}
build_metadata_path=/usr/local/share/readsb/build-metadata.env

# ── Restart backoff ───────────────────────────────────────────────────────────
# Prevent tight crash loops when the SDR device is unavailable.  Track
# consecutive failures via an ephemeral file in /run and apply a progressive
# delay (5s → 10s → 15s … max 60s) before each attempt.
#
# Note: the fail counter is pre-incremented BEFORE exec (since exec replaces
# the process and EXIT traps never fire).  A companion sentinel file written
# after readsb has been running for 30+ seconds resets the counter (see below).
_fail_count_file="/run/readsb-fail-count"
_fail_count=0
if [[ -f "${_fail_count_file}" ]]; then
    _fail_count=$(tr -d '[:space:]' < "${_fail_count_file}")
    _fail_count=${_fail_count:-0}
fi
_is_restart=false
if [[ ${_fail_count} -gt 0 ]]; then
    _is_restart=true
    _backoff=$(( _fail_count * 5 ))
    [[ ${_backoff} -gt 60 ]] && _backoff=60
    log_warn "Previous launch failed (attempt #${_fail_count}). Waiting ${_backoff}s before retry."
    sleep "${_backoff}"
fi

# Import build metadata captured from upstream readsb so these values are
# available to the service process in production.
if [[ -r "${build_metadata_path}" ]]; then
    set -a
    # shellcheck disable=SC1090
    . "${build_metadata_path}"
    set +a
fi

# Create runtime directory at service start in case one-shot init did not run yet.
if ! mkdir -p "${readsb_run_dir}"; then
    log_fatal "unable to create READSB_RUN_DIR (${readsb_run_dir})."
    log_fatal "If running as non-root, ensure /run tmpfs uses matching uid/gid."
    exit 1
fi

readsb_args_source="default"
if [[ -n ${READSB_ARGS:-} ]]; then
    readsb_args_source="env"
    read -r -a readsb_args <<< "${READSB_ARGS}"
else
    readsb_args=(
        --net
        --write-json "${readsb_run_dir}"
        --write-json-every 1
        --db-file "${tar1090_db_path}"
    )
fi

has_readsb_opt() {
    local opt=$1
    local token

    for token in "${readsb_args[@]}"; do
        if [[ ${token} == "${opt}" || ${token} == "${opt}="* ]]; then
            return 0
        fi
    done

    return 1
}

# Keep key file-output defaults even when READSB_ARGS is user-specified.
if ! has_readsb_opt "--write-json"; then
    readsb_args+=(--write-json "${readsb_run_dir}")
fi

if ! has_readsb_opt "--db-file"; then
    readsb_args+=(--db-file "${tar1090_db_path}")
fi

# Resolve the value of --device-type from the effective args.
_dt_val=""
_dt_prev=""
for _dt_tok in "${readsb_args[@]}"; do
    if [[ ${_dt_prev} == "--device-type" ]]; then
        _dt_val=${_dt_tok}
        break
    fi
    if [[ ${_dt_tok} == "--device-type="* ]]; then
        _dt_val=${_dt_tok#--device-type=}
        break
    fi
    _dt_prev=${_dt_tok}
done
unset _dt_prev _dt_tok

# If device type is rtlsdr and no --gain was provided, apply gain source:
# 1. READSB_AUTOGAIN=true → read managed gain from /config/autogain-gain
# 2. Otherwise → default to --gain auto (hardware AGC)
if [[ ${_dt_val} == "rtlsdr" ]] && ! has_readsb_opt "--gain"; then
    _autogain_file="/config/autogain-gain"
    if [[ "${READSB_AUTOGAIN:-true}" =~ ^(true|yes|1)$ ]] && [[ -f "${_autogain_file}" ]]; then
        _ag_val=$(tr -d '[:space:]' < "${_autogain_file}")
        if [[ -n "${_ag_val}" ]]; then
            readsb_args+=(--gain "${_ag_val}")
            log_info "Using autogain-managed gain: ${_ag_val}"
        else
            readsb_args+=(--gain auto)
            log_warn "Autogain file empty, falling back to --gain auto"
        fi
    else
        readsb_args+=(--gain auto)
    fi
fi

# ── Kernel DVB module removal ─────────────────────────────────────────────────
# The dvb_usb_rtl28xxu kernel module auto-attaches to RTL2832U devices and
# prevents userspace access (librtlsdr).  Attempt to unload it automatically
# before bias-T or readsb tries to open the device.  On balenaOS the
# io.balena.features.kernel-modules label grants rmmod access; on plain Docker
# the container typically needs --privileged or SYS_MODULE capability.
#
# IMPORTANT: unbind all USB interfaces from the DVB driver BEFORE attempting
# rmmod — the module cannot be unloaded while it still has bound devices
# (non-zero reference count).  Previous versions tried rmmod first, which
# always failed because the devices were still bound.
if [[ ${_dt_val} == "rtlsdr" ]] && [[ -d /sys/module/dvb_usb_rtl28xxu ]]; then
    log_warn "Kernel module 'dvb_usb_rtl28xxu' is loaded — attempting automatic removal."

    # Step 1: Unbind all USB interfaces from DVB driver (drops refcount to 0)
    _dvb_driver_path="/sys/bus/usb/drivers/dvb_usb_rtl28xxu"
    _dvb_unbound=false
    if [[ -d "${_dvb_driver_path}" ]]; then
        for _bound in "${_dvb_driver_path}"/*/; do
            _intf=$(basename "${_bound}")
            [[ "${_intf}" == *:* ]] || continue
            if echo -n "${_intf}" > "${_dvb_driver_path}/unbind" 2>/dev/null; then
                log_info "Unbound USB interface '${_intf}' from dvb_usb_rtl28xxu via sysfs."
                _dvb_unbound=true
            else
                log_warn "Failed to unbind '${_intf}' from dvb_usb_rtl28xxu via sysfs."
            fi
        done
        [[ "${_dvb_unbound}" == "true" ]] && sleep 1
    fi

    # Step 2: Remove the kernel modules (should succeed now that refcount is 0)
    _mod_removed=false
    for _mod in dvb_usb_rtl28xxu rtl2832 rtl2830; do
        if [[ -d /sys/module/${_mod} ]]; then
            if rmmod "${_mod}" 2>/dev/null; then
                log_info "Removed kernel module '${_mod}'."
                _mod_removed=true
            else
                log_warn "Failed to remove '${_mod}' (need --privileged or SYS_MODULE capability)."
            fi
        fi
    done
    if [[ "${_mod_removed}" == "true" ]]; then
        # Allow device nodes to settle after module removal
        sleep 2
    fi

    # Step 3: If rmmod failed but unbind succeeded, the DVB module is still
    # loaded and could re-attach.  Perform a USB device reset on each RTL-SDR
    # dongle to clear stale DVB state from the RTL2832U chip, then re-unbind
    # in case the reset triggered automatic driver re-probing.
    if [[ "${_dvb_unbound}" == "true" && "${_mod_removed}" != "true" ]]; then
        if command -v usb-reset >/dev/null 2>&1; then
            while IFS= read -r _devpath; do
                if [[ -c "${_devpath}" ]]; then
                    log_info "Resetting USB device: ${_devpath} (clearing stale DVB state)"
                    usb-reset "${_devpath}" 2>&1 | while IFS= read -r _line; do
                        log_info "usb-reset: ${_line}"
                    done || true
                fi
            done < <(lsusb 2>/dev/null | grep -iE '0bda:(2832|2838)' | \
                     sed -nE 's|^Bus ([0-9]+) Device ([0-9]+):.*|/dev/bus/usb/\1/\2|p')
            sleep 2

            # Re-unbind: USB reset re-enumerates the device, which may cause
            # the still-loaded DVB module to re-attach automatically.
            if [[ -d "${_dvb_driver_path}" ]]; then
                for _bound in "${_dvb_driver_path}"/*/; do
                    _intf=$(basename "${_bound}")
                    [[ "${_intf}" == *:* ]] || continue
                    if echo -n "${_intf}" > "${_dvb_driver_path}/unbind" 2>/dev/null; then
                        log_info "Re-unbound '${_intf}' from dvb_usb_rtl28xxu after USB reset."
                    fi
                done
                sleep 1
            fi
        else
            log_warn "usb-reset not found — RTL-SDR may not receive data if DVB left stale state."
            log_warn "On the host, blacklist the module: echo 'blacklist dvb_usb_rtl28xxu' > /etc/modprobe.d/blacklist-rtlsdr.conf"
        fi
    fi
fi

# ── Bias-T ────────────────────────────────────────────────────────────────────
# Enable bias-T power on the RTL-SDR dongle (for powered LNAs/active antennas).
# Requires rtl_biast (provided by rtl-sdr package).
if [[ ${_dt_val} == "rtlsdr" ]] && [[ "${READSB_BIASTEE:-false}" =~ ^(true|yes|1)$ ]]; then
    if command -v rtl_biast >/dev/null 2>&1; then
        _bt_args=(-b 1)
        # If a specific device serial is known, target that dongle
        if [[ -n "${READSB_DEVICE:-}" ]]; then
            _bt_args+=(-d "${READSB_DEVICE}")
        elif [[ -n "${SDR_1090_SERIAL:-}" ]]; then
            _bt_args+=(-d "${SDR_1090_SERIAL}")
        fi
        log_info "Enabling bias-T: rtl_biast ${_bt_args[*]}"
        if ! rtl_biast "${_bt_args[@]}" 2>&1 | while IFS= read -r _line; do log_info "bias-T: ${_line}"; done; then
            log_warn "rtl_biast failed — bias-T may not be enabled. Check dongle support."
        fi
        # Allow USB device to settle after rtl_biast releases it
        sleep 1
    else
        log_warn "READSB_BIASTEE=true but rtl_biast not found. Install rtl-sdr package."
    fi
fi

# Suppress per-message decoder output unless user explicitly wants it (--debug / no --quiet).
if ! has_readsb_opt "--quiet" && ! has_readsb_opt "--debug"; then
    readsb_args+=(--quiet)
fi

# Apply SDR device assignment (manual READSB_DEVICE or auto-detected SDR_1090_INDEX)
if [[ ${_dt_val} == "rtlsdr" ]] && ! has_readsb_opt "--device"; then
    if [[ -n "${READSB_DEVICE:-}" ]]; then
        readsb_args+=(--device "${READSB_DEVICE}")
        log_info "Using manually assigned 1090 MHz dongle: --device ${READSB_DEVICE}"
    elif [[ -n "${SDR_1090_SERIAL:-}" ]]; then
        # Prefer serial over index: serial is stable across reboots
        readsb_args+=(--device "${SDR_1090_SERIAL}")
        log_info "Using auto-detected 1090 MHz dongle: --device ${SDR_1090_SERIAL} (serial)"
    elif [[ -n "${SDR_1090_INDEX:-}" ]]; then
        readsb_args+=(--device "${SDR_1090_INDEX}")
        log_info "Using auto-detected 1090 MHz dongle: --device ${SDR_1090_INDEX} (index)"
    fi
fi

# --- Feed profile: append --net-connector args per active profile ---
# shellcheck source=/usr/local/bin/feed-profiles.sh
. /usr/local/bin/feed-profiles.sh
parse_feed_profiles

feed_active=false
if [[ ${#FEED_PROFILE_LIST[@]} -gt 0 ]]; then
    feed_active=true

    # Add a --net-connector for each active profile (with per-profile UUID)
    for _fp in "${FEED_PROFILE_LIST[@]}"; do
        _fc=$(get_feed_connector "${_fp}")
        if [[ -z "${_fc}" ]]; then
            log_warn "Unknown feed profile '${_fp}' -- skipping."
            continue
        fi
        # Inject per-profile UUID into the connector string
        _fp_uuid=$(get_profile_uuid "${_fp}")
        if [[ -n "${_fp_uuid}" ]]; then
            _fc="${_fc},uuid=${_fp_uuid}"
        fi
        readsb_args+=(--net-connector "${_fc}")

        # Add secondary/failover connector if the profile has one
        _fc2=$(get_feed_connector_secondary "${_fp}")
        if [[ -n "${_fc2}" ]]; then
            if [[ -n "${_fp_uuid}" ]]; then
                _fc2="${_fc2},uuid=${_fp_uuid}"
            fi
            readsb_args+=(--net-connector "${_fc2}")
        fi
    done

    # UAT input connector (only if FEED_UAT_INPUT is set, e.g. "dump978:30978")
    if [[ -n "${FEED_UAT_INPUT:-}" ]]; then
        _uat_host="${FEED_UAT_INPUT%%:*}"
        _uat_port="${FEED_UAT_INPUT##*:}"
        if [[ -n "${_uat_host}" ]] && [[ -n "${_uat_port}" ]]; then
            readsb_args+=(--net-connector "${_uat_host},${_uat_port},uat_in,silent_fail")
        fi
    fi

    # Shared feed tuning args -- only add if user hasn't already specified them
    if ! has_readsb_opt "--net-beast-reduce-interval"; then
        readsb_args+=(--net-beast-reduce-interval 0.5)
    fi
    if ! has_readsb_opt "--net-heartbeat"; then
        readsb_args+=(--net-heartbeat 60)
    fi
    if ! has_readsb_opt "--net-ro-size"; then
        readsb_args+=(--net-ro-size 1280)
    fi
    if ! has_readsb_opt "--net-ro-interval"; then
        readsb_args+=(--net-ro-interval 0.2)
    fi
    if ! has_readsb_opt "--json-location-accuracy"; then
        readsb_args+=(--json-location-accuracy 2)
    fi
    if ! has_readsb_opt "--range-outline-hours"; then
        readsb_args+=(--range-outline-hours 24)
    fi
    if ! has_readsb_opt "--max-range"; then
        readsb_args+=(--max-range 450)
    fi
    if ! has_readsb_opt "--write-json-every"; then
        readsb_args+=(--write-json-every 1)
    fi

    # Lat/lon from FEED_LAT/FEED_LON (fallback if not already in READSB_ARGS)
    if [[ -n "${FEED_LAT:-}" ]] && ! has_readsb_opt "--lat"; then
        readsb_args+=(--lat "${FEED_LAT}")
    fi
    if [[ -n "${FEED_LON:-}" ]] && ! has_readsb_opt "--lon"; then
        readsb_args+=(--lon "${FEED_LON}")
    fi
fi

# ── Beast-input port (READSB_NET_BI_PORT) ─────────────────────────────────────
# Applied unconditionally (not feed-profile-specific) so that beast input/output
# ports are configured even when no feed profiles are active.
if [[ -n "${READSB_NET_BI_PORT:-}" ]] && ! has_readsb_opt "--net-bi-port"; then
    readsb_args+=(--net-bi-port "${READSB_NET_BI_PORT}")
fi

# ── Beast-output port (READSB_NET_BO_PORT) ────────────────────────────────────
if [[ -n "${READSB_NET_BO_PORT:-}" ]] && ! has_readsb_opt "--net-bo-port"; then
    readsb_args+=(--net-bo-port "${READSB_NET_BO_PORT}")
fi

readsb_args_rendered=$(printf '%q ' "${readsb_args[@]}")
readsb_args_rendered=${readsb_args_rendered% }

build_version=${VERSION:-unknown}
if [[ -r /build_version ]]; then
    build_version=$(< /build_version)
fi

# On restarts, log a compact summary instead of the full config dump.
if [[ "${_is_restart}" == "true" ]]; then
    log_info "readsb restarting (attempt #$((_fail_count + 1))). effective_ARGS: ${readsb_args_rendered}"
else
    log_info "readsb container startup configuration"
    log_kv "build_version" "${build_version}"
    log_kv "VERSION" "${VERSION:-unknown}"
    log_kv "BUILD_DATE" "${BUILD_DATE:-unknown}"
    log_kv "VCS_REF" "${VCS_REF:-unknown}"
    log_kv "PUID" "${PUID:-unset}"
    log_kv "PGID" "${PGID:-unset}"
    log_kv "UMASK" "${UMASK:-unset}"
    log_kv "TZ" "${TZ:-unset}"
    log_kv "READSB_USER" "${readsb_user}"
    log_kv "READSB_ARGS(raw)" "${READSB_ARGS:-unset}"
    log_kv "READSB_ARGS(src)" "${readsb_args_source}"
    log_kv "READSB_RUN_DIR" "${readsb_run_dir}"
    log_kv "TAR1090_DB_PATH" "${tar1090_db_path}"
    log_kv "LSIO_NON_ROOT_USER" "${LSIO_NON_ROOT_USER:-unset}"
    log_kv "effective_ARGS" "${readsb_args_rendered}"
    log_kv "FEED_PROFILES" "${FEED_PROFILES:-none}"
    log_kv "FEED_LAT" "${FEED_LAT:-unset}"
    log_kv "FEED_LON" "${FEED_LON:-unset}"
    log_kv "AUTO_LOCATION" "${READSB_AUTO_LOCATION:-true}"
    log_kv "PUBLIC_IP" "${PUBLIC_IP:-unknown}"
    log_kv "AUTOGAIN" "${READSB_AUTOGAIN:-true}"
    if [[ "${READSB_AUTOGAIN:-true}" =~ ^(true|yes|1)$ ]]; then
        log_kv "AUTOGAIN_INTERVAL" "${READSB_AUTOGAIN_INTERVAL:-3600}s"
        log_kv "AUTOGAIN_LOW" "${READSB_AUTOGAIN_LOW:-0.5}%"
        log_kv "AUTOGAIN_HIGH" "${READSB_AUTOGAIN_HIGH:-7.0}%"
        log_kv "AUTOGAIN_STALL_CYCLES" "${READSB_AUTOGAIN_STALL_CYCLES:-3}"
    fi
    log_kv "BIASTEE" "${READSB_BIASTEE:-false}"
    log_kv "NET_BI_PORT" "${READSB_NET_BI_PORT:-unset}"
    log_kv "NET_BO_PORT" "${READSB_NET_BO_PORT:-unset}"
    if [[ "${feed_active}" == "true" ]]; then
        log_kv "FEED_UAT_INPUT" "${FEED_UAT_INPUT:-disabled}"
        log_kv "FEED_STATS" "${FEED_STATS_ENABLED:-true}"
        log_kv "ADSBX_UPLOAD" "$(has_feed_profile adsbexchange && echo 'enabled (same UUID as beast feed)' || echo 'disabled (adsbexchange not in FEED_PROFILES)')"
        for _fp in "${FEED_PROFILE_LIST[@]}"; do
            _fc=$(get_feed_connector "${_fp}")
            _fc2=$(get_feed_connector_secondary "${_fp}")
            _ms=$(get_mlat_server "${_fp}")
            _fp_uuid=$(get_profile_uuid "${_fp}")
            log_kv "FEED[${_fp}]" "${_fc}"
            if [[ -n "${_fc2}" ]]; then
                log_kv "FEED[${_fp}:secondary]" "${_fc2}"
            fi
            _fp_uuid_file=$(get_profile_uuid_file "${_fp}")
            log_kv "UUID[${_fp}]" "${_fp_uuid:-missing}"
            log_kv "UUID_FILE[${_fp}]" "${_fp_uuid_file}"
            if [[ "${_fp}" == "adsbexchange" && -n "${_fp_uuid}" ]]; then
                log_kv "ADSBX_STATS_URL" "https://www.adsbexchange.com/api/feeders/?feed=${_fp_uuid}"
            fi
            if [[ -n "${_ms}" ]]; then
                log_kv "MLAT[${_fp}]" "${_ms} (optional — requires separate mlat-client container)"
            fi
        done
    fi

    if [[ ${_dt_val} == "rtlsdr" ]]; then
        usb_char_devs=0
        if [[ -d /dev/bus/usb ]]; then
            usb_char_devs=$(find /dev/bus/usb -type c 2>/dev/null | wc -l | tr -d '[:space:]')
        fi
        log_kv "USB_CHAR_DEVS" "${usb_char_devs}"

        if command -v lsusb >/dev/null 2>&1; then
            lsusb_compact=$(lsusb 2>/dev/null | paste -sd '; ' -)
            log_kv "LSUSB" "${lsusb_compact:-none}"
        else
            log_kv "LSUSB" "unavailable"
        fi

        if [[ ! -e /dev/bus/usb ]]; then
            log_warn "/dev/bus/usb is missing. Local RTL-SDR access will fail unless using network-only input."
        elif [[ ! -r /dev/bus/usb ]]; then
            log_warn "/dev/bus/usb is not readable by the container. Check device mapping and runtime permissions."
        elif [[ ${usb_char_devs} -eq 0 ]]; then
            log_warn "/dev/bus/usb is present but contains no USB device nodes."
            log_warn "Check host USB passthrough support and that the SDR is physically attached."
        fi

        # ── Kernel DVB module conflict detection (fallback) ──────────────────
        # If the earlier unbind+rmmod+reset sequence didn't fully clear DVB,
        # warn the user to blacklist the module on the host.
        if [[ -d /sys/module/dvb_usb_rtl28xxu ]]; then
            _dvb_driver_path="/sys/bus/usb/drivers/dvb_usb_rtl28xxu"
            _has_bound=false
            if [[ -d "${_dvb_driver_path}" ]]; then
                for _bound in "${_dvb_driver_path}"/*/; do
                    _intf=$(basename "${_bound}")
                    [[ "${_intf}" == *:* ]] && _has_bound=true && break
                done
            fi
            if [[ "${_has_bound}" == "true" ]]; then
                log_warn "Kernel module 'dvb_usb_rtl28xxu' is still loaded with bound devices."
                log_warn "On the host, create /etc/modprobe.d/blacklist-rtlsdr.conf with:"
                log_warn "  blacklist dvb_usb_rtl28xxu"
                log_warn "  blacklist rtl2832"
                log_warn "  blacklist rtl2830"
                log_warn "Then reboot the host or run: sudo rmmod dvb_usb_rtl28xxu rtl2832 rtl2830"
            fi
        fi
    fi
fi  # end _is_restart check

# ── Sysfs USB unbind (final safety check before exec) ────────────────────────
# If the dvb_usb_rtl28xxu kernel driver is STILL bound to any RTL2832U device
# (e.g. the earlier removal was skipped on a compact restart log path),
# unbind it via sysfs and perform a USB reset to clear stale chip state.
if [[ ${_dt_val} == "rtlsdr" ]]; then
    _dvb_driver_path="/sys/bus/usb/drivers/dvb_usb_rtl28xxu"
    if [[ -d "${_dvb_driver_path}" ]]; then
        _unbound=false
        for _bound in "${_dvb_driver_path}"/*/; do
            _intf=$(basename "${_bound}")
            [[ "${_intf}" == *:* ]] || continue
            if echo -n "${_intf}" > "${_dvb_driver_path}/unbind" 2>/dev/null; then
                log_info "Unbound USB interface '${_intf}' from dvb_usb_rtl28xxu via sysfs."
                _unbound=true
            else
                log_warn "Failed to unbind '${_intf}' from dvb_usb_rtl28xxu via sysfs."
            fi
        done
        if [[ "${_unbound}" == "true" ]]; then
            sleep 1
            # USB reset to clear stale DVB state from the RTL2832U chip
            if command -v usb-reset >/dev/null 2>&1; then
                while IFS= read -r _devpath; do
                    if [[ -c "${_devpath}" ]]; then
                        log_info "Resetting USB device: ${_devpath} (post DVB-unbind)"
                        usb-reset "${_devpath}" 2>&1 | while IFS= read -r _line; do
                            log_info "usb-reset: ${_line}"
                        done || true
                    fi
                done < <(lsusb 2>/dev/null | grep -iE '0bda:(2832|2838)' | \
                         sed -nE 's|^Bus ([0-9]+) Device ([0-9]+):.*|/dev/bus/usb/\1/\2|p')
                sleep 2
                # Re-unbind: reset may re-trigger DVB driver attachment
                for _bound in "${_dvb_driver_path}"/*/; do
                    _intf=$(basename "${_bound}")
                    [[ "${_intf}" == *:* ]] || continue
                    echo -n "${_intf}" > "${_dvb_driver_path}/unbind" 2>/dev/null || true
                done
                sleep 1
            fi
        fi
    fi
fi

# ── Wait for listening ports to be available ──────────────────────────────────
# After a crash, TCP sockets may linger in TIME_WAIT.  Wait up to 15 seconds
# for the ports specified in --net-bi-port / --net-bo-port to become available.
_wait_for_ports() {
    local _ports_csv=""
    local _prev=""
    for _tok in "${readsb_args[@]}"; do
        if [[ "${_prev}" == "--net-bi-port" || "${_prev}" == "--net-bo-port" ]]; then
            _ports_csv="${_ports_csv:+${_ports_csv},}${_tok}"
        elif [[ "${_tok}" == "--net-bi-port="* ]]; then
            _ports_csv="${_ports_csv:+${_ports_csv},}${_tok#--net-bi-port=}"
        elif [[ "${_tok}" == "--net-bo-port="* ]]; then
            _ports_csv="${_ports_csv:+${_ports_csv},}${_tok#--net-bo-port=}"
        fi
        _prev="${_tok}"
    done
    [[ -z "${_ports_csv}" ]] && return 0

    IFS=',' read -ra _port_list <<< "${_ports_csv}"
    local _waited=false
    for _p in "${_port_list[@]}"; do
        local _attempts=0
        while ss -tlnH "sport = :${_p}" 2>/dev/null | grep -q ":${_p}" && [[ ${_attempts} -lt 15 ]]; do
            if [[ "${_waited}" == "false" ]]; then
                log_warn "Port ${_p} still in use — waiting for release."
                _waited=true
            fi
            sleep 1
            _attempts=$(( _attempts + 1 ))
        done
        if [[ ${_attempts} -ge 15 ]]; then
            log_warn "Port ${_p} is still occupied after 15s. readsb may fail to bind."
        fi
    done
}
_wait_for_ports

# ── Exec readsb with syslog-format log prefixing ─────────────────────────────
# Pipe readsb stdout/stderr through awk to tag every line with a syslog-format
# prefix including a timestamp (readsb outputs decoder data to stderr).
LOG_PIPE=$(log_pipe_cmd decoder)

# Pre-increment the fail counter BEFORE exec.  exec replaces this process so
# EXIT traps never fire — we must assume failure upfront.  On successful
# startup (30+ seconds of runtime), svc-feed-stats or svc-autogain resets it.
echo "$(( _fail_count + 1 ))" > "${_fail_count_file}"

if [[ -z ${LSIO_NON_ROOT_USER:-} ]]; then
    lsiown -R "${readsb_user}:${readsb_user}" "${readsb_run_dir}"
    exec s6-setuidgid "${readsb_user}" /bin/bash -c "
        /usr/local/bin/readsb $(printf '%q ' "${readsb_args[@]}") 2>&1 \
            | ${LOG_PIPE}
    "
fi

if [[ ! -w ${readsb_run_dir} ]]; then
    log_fatal "READSB_RUN_DIR (${readsb_run_dir}) is not writable by current user."
    log_fatal "When forcing user mode, set /run tmpfs uid/gid to match that user."
    exit 1
fi

exec /bin/bash -c "
    /usr/local/bin/readsb $(printf '%q ' "${readsb_args[@]}") 2>&1 \
        | ${LOG_PIPE}
"
